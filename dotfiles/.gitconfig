[user]
	email = andre.jonas@gmail.com
	name = André Jonas
	signingkey = ssh-rsa 

[core]
	excludesfile = ~/.gitignore_global
	editor = code --wait

[alias] 
	last = log -1 HEAD
	uncommit = reset --soft HEAD^
	unstage = reset HEAD --
	staged = diff --cached
	vlog = log --graph --full-history --all --color --pretty=format:"%x1b[31m%h%x09%x1b[32m%d%x1b[0m%x20%s"
	previous = checkout @{-1}

[commit]
	gpgsign = true

[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers

[url "git@github.com:"]

	insteadOf = "gh:"
#        insteadOf = "https://github.com/"
	pushInsteadOf = "github:"
	pushInsteadOf = "git://github.com/"

[url "git://github.com/"]

	insteadOf = "github:"

[url "git@gist.github.com:"]

	insteadOf = "gst:"
	pushInsteadOf = "gist:"
	pushInsteadOf = "git://gist.github.com/"

[url "git://gist.github.com/"]

	insteadOf = "gist:"

[tag]
	gpgsign = true
